---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import UIShowcase from '../components/UIShowcase.astro';
import Features from '../components/Features.astro';
import CodeDemo from '../components/CodeDemo.astro';
import Architecture from '../components/Architecture.astro';
import Quickstart from '../components/Quickstart.astro';
import Ports from '../components/Ports.astro';
import Safety from '../components/Safety.astro';
import Compare from '../components/Compare.astro';
---

<BaseLayout
  title="deadletter — local SMTP, Kafka, Redis & webhook inbox for developers"
  description="deadletter is a local-first message observability cockpit for developers. Capture SMTP email on :1025, browse Kafka topics and Schema Registry, inspect Redis keys and pub/sub, debug webhooks — all in one UI at localhost:8025. One Go binary. Zero accidental deliveries. A superset of MailHog, Mailpit, Kafka UI, RedisInsight and webhook.site."
>
  <Nav />
  <Hero />
  <UIShowcase />
  <Features />
  <Compare />
  <CodeDemo />
  <Architecture />
  <Quickstart />
  <Ports />
  <Safety />

  <section id="cta" class="py-20 sm:py-28">
    <div class="container-x reveal">
      <div class="card card-gloss relative overflow-hidden p-8 sm:p-12 text-center"
           style="background:radial-gradient(ellipse 90% 120% at 50% 0%, color-mix(in oklab, var(--accent) 22%, transparent), transparent 60%), var(--bg-elev)">
        <div class="eyebrow mb-4 justify-center inline-flex">
          <span class="live-dot" aria-hidden="true"></span>
          Ready when you are
        </div>
        <h2 class="text-3xl sm:text-5xl tracking-[-0.03em] font-semibold leading-[1.04] max-w-3xl mx-auto">
          Stop sending test email
          <span style="color:var(--accent)">into the void.</span>
        </h2>
        <p class="mt-5 max-w-xl mx-auto text-[15.5px] leading-relaxed" style="color:var(--muted)">
          One <code class="font-mono text-[14px]" style="color:var(--fg)">docker run</code> — SMTP, Kafka, Redis, and webhooks
          all land in a UI you can actually reason about.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a href="#quickstart"
             class="inline-flex items-center gap-2 h-11 px-5 rounded-xl text-sm font-medium bg-[color:var(--fg)] text-[color:var(--bg)] hover:opacity-90 transition-opacity">
            docker run it
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://github.com/deadletter-engine/deadletter" rel="noopener noreferrer" target="_blank"
             class="inline-flex items-center gap-2 h-11 px-5 rounded-xl text-sm font-medium border line hover:border-[color:var(--line-strong)] transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.73 5.5.73 11.77c0 4.99 3.24 9.22 7.73 10.72.57.1.78-.25.78-.55v-2c-3.15.68-3.81-1.35-3.81-1.35-.52-1.3-1.26-1.65-1.26-1.65-1.03-.7.08-.69.08-.69 1.14.08 1.74 1.17 1.74 1.17 1.01 1.73 2.66 1.23 3.31.94.1-.74.4-1.23.72-1.51-2.51-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.17-3.04-.12-.29-.51-1.46.11-3.04 0 0 .95-.3 3.12 1.16a10.8 10.8 0 0 1 2.85-.38c.97 0 1.94.13 2.85.38 2.17-1.46 3.12-1.16 3.12-1.16.62 1.58.23 2.75.11 3.04.73.79 1.17 1.8 1.17 3.04 0 4.36-2.66 5.3-5.19 5.58.41.35.77 1.05.77 2.11v3.12c0 .3.2.66.79.54 4.49-1.5 7.72-5.73 7.72-10.72C23.27 5.5 18.27.5 12 .5Z"/></svg>
            Star on GitHub
          </a>
          <span class="font-mono text-[12px]" style="color:var(--subtle)">v1.2.0</span>
        </div>
      </div>
    </div>
  </section>

  <footer class="border-t line mt-6">
    <div class="container-x py-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="lg:col-span-2">
        <a href="#top" class="flex items-center gap-2 font-mono text-sm">
          <span aria-hidden="true" class="text-lg leading-none">&#128238;</span>
          <span class="font-semibold">deadLetter</span>
        </a>
        <p class="mt-3 max-w-sm text-[13.5px] leading-relaxed" style="color:var(--muted)">
          Local-first message observability for development. Capture, inspect,
          replay — without surprising anyone in production.
        </p>
        <div class="mt-5 flex flex-wrap gap-1.5">
          <span class="tag">Go</span>
          <span class="tag">Next.js</span>
          <span class="tag">Docker</span>
          <span class="tag">Homebrew</span>
        </div>
      </div>

      <nav aria-label="Footer primary" class="text-[13.5px]">
        <div class="numeral mb-3">product</div>
        <ul class="space-y-2" style="color:var(--muted)">
          <li><a href="#features" class="hover:text-[color:var(--fg)] transition-colors">Features</a></li>
          <li><a href="#architecture" class="hover:text-[color:var(--fg)] transition-colors">Architecture</a></li>
          <li><a href="#api" class="hover:text-[color:var(--fg)] transition-colors">HTTP API & SSE</a></li>
          <li><a href="#ports" class="hover:text-[color:var(--fg)] transition-colors">Ports & routes</a></li>
          <li><a href="#safety" class="hover:text-[color:var(--fg)] transition-colors">Safety</a></li>
        </ul>
      </nav>

      <nav aria-label="Footer resources" class="text-[13.5px]">
        <div class="numeral mb-3">resources</div>
        <ul class="space-y-2" style="color:var(--muted)">
          <li><a href="#quickstart" class="hover:text-[color:var(--fg)] transition-colors">Quickstart</a></li>
          <li><a href="https://github.com/deadletter-engine/deadletter" rel="noopener noreferrer" target="_blank" class="hover:text-[color:var(--fg)] transition-colors">GitHub</a></li>
          <li><a href="https://hub.docker.com/r/peixotomdb/deadletter" rel="noopener noreferrer" target="_blank" class="hover:text-[color:var(--fg)] transition-colors">Docker Hub</a></li>
          <li><a href="#cta" class="hover:text-[color:var(--fg)] transition-colors">Webhooks</a></li>
        </ul>
      </nav>
    </div>

    <div class="divider"></div>
    <div class="container-x py-6 flex flex-col sm:flex-row items-center justify-between gap-3 font-mono text-[11.5px]" style="color:var(--subtle)">
      <span>© 2026 deadLetter — where messages go to rest.</span>
      <span class="flex items-center gap-2">
        <span class="live-dot" aria-hidden="true"></span>
        all systems quiet · :1025 · :8025
      </span>
    </div>
  </footer>

  <style>
    .cta-browser {
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: color-mix(in oklab, var(--bg-elev) 88%, transparent);
      box-shadow:
        0 1px 0 color-mix(in oklab, var(--fg) 6%, transparent) inset,
        0 30px 70px -30px color-mix(in oklab, var(--accent) 40%, transparent),
        0 10px 30px -10px rgba(0, 0, 0, 0.45);
    }
    .cta-chrome {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 13px;
      border-bottom: 1px solid var(--line);
      background: color-mix(in oklab, var(--bg-elev) 70%, transparent);
    }
    .cta-url {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 11px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: color-mix(in oklab, var(--bg) 55%, transparent);
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--muted);
    }
    .cta-dash {
      padding: 22px 20px 20px;
      background:
        radial-gradient(ellipse 70% 80% at 50% -20%, color-mix(in oklab, var(--accent) 18%, transparent), transparent 55%),
        color-mix(in oklab, var(--bg) 50%, black);
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
    }
    .cta-title {
      font-size: 26px;
      font-weight: 600;
      letter-spacing: -0.028em;
      color: var(--fg);
      text-align: center;
      line-height: 1.08;
      margin: 2px 0 6px;
    }
    .cta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      width: 100%;
    }
    .cta-stats {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-top: 2px;
    }
    .cta-stats .dash-v {
      font-family: var(--font-mono);
      font-size: 15px;
      color: var(--fg);
      white-space: nowrap;
    }
    .cta-stats .dash-k {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.12em;
      color: var(--subtle);
      text-transform: uppercase;
    }

    /* reused from UIShowcase — scoped styles don't cross components */
    .live-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 11px;
      border-radius: 999px;
      border: 1px solid color-mix(in oklab, #22c55e 45%, var(--line));
      background: color-mix(in oklab, #22c55e 8%, transparent);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      color: #86efac;
    }
    .dash-strike {
      position: relative;
      color: color-mix(in oklab, var(--accent) 85%, var(--fg));
    }
    .dash-strike::after {
      content: "";
      position: absolute;
      left: -4%;
      right: -4%;
      top: 50%;
      height: 3px;
      background: var(--accent);
      transform: rotate(-3deg);
      border-radius: 2px;
    }
    .dash-card {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 12px 13px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: color-mix(in oklab, var(--bg-elev) 85%, transparent);
    }
    .dash-card.accent {
      border-color: color-mix(in oklab, var(--accent) 45%, var(--line));
      background:
        linear-gradient(180deg, color-mix(in oklab, var(--accent) 10%, transparent), transparent 60%),
        color-mix(in oklab, var(--bg-elev) 85%, transparent);
    }
    .dash-card-head {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .dash-ico {
      display: inline-flex;
      width: 26px;
      height: 26px;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      border: 1px solid var(--line);
      color: var(--accent);
      background: color-mix(in oklab, var(--accent) 10%, transparent);
      flex-shrink: 0;
    }
    .dash-card-title {
      font-size: 12.5px;
      font-weight: 600;
      color: var(--fg);
    }
    .dash-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 2px 9px;
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 10.5px;
      width: max-content;
    }
    .dash-status span {
      width: 5px;
      height: 5px;
      border-radius: 999px;
    }
    .dash-status.ok { color: #86efac; background: color-mix(in oklab, #22c55e 12%, transparent); }
    .dash-status.ok span { background: #22c55e; box-shadow: 0 0 0 3px color-mix(in oklab, #22c55e 25%, transparent); }
    .dash-status.warn { color: var(--warn); background: color-mix(in oklab, var(--warn) 12%, transparent); }
    .dash-status.warn span { background: var(--warn); box-shadow: 0 0 0 3px color-mix(in oklab, var(--warn) 25%, transparent); }
    .nav-badge.accent {
      display: inline-block;
      padding: 1px 5px;
      border-radius: 4px;
      background: var(--accent);
      color: #0b0a09;
      font-family: var(--font-mono);
      font-weight: 700;
      letter-spacing: 0.05em;
    }
  </style>
</BaseLayout>
