---
---
<header class="sticky top-0 z-50 glass border-b line nav-root">
  <div class="container-x flex h-14 items-center justify-between gap-3">
    <a href="#top" class="flex items-center gap-2 font-mono text-sm tracking-tight shrink-0">
      <span aria-hidden="true" class="text-lg leading-none">&#128238;</span>
      <span class="font-semibold">deadLetter</span>
      <span class="text-[10px] px-1.5 py-0.5 rounded border line hidden sm:inline" style="color:var(--muted)">v1.2.0</span>
    </a>
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6 text-[13px]" style="color:var(--muted)">
      <a href="#ui" class="nav-link">UI</a>
      <a href="#features" class="nav-link">Features</a>
      <a href="#compare" class="nav-link">Compare</a>
      <a href="#architecture" class="nav-link">Architecture</a>
      <a href="#quickstart" class="nav-link">Quickstart</a>
      <a href="#safety" class="nav-link">Safety</a>
    </nav>
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/deadletter-engine/deadletter"
        rel="noopener noreferrer"
        target="_blank"
        class="inline-flex items-center gap-2 h-9 px-3 rounded-lg text-[12px] font-mono bg-[color:var(--fg)] text-[color:var(--bg)] hover:opacity-90 transition-opacity"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.73 5.5.73 11.77c0 4.99 3.24 9.22 7.73 10.72.57.1.78-.25.78-.55v-2c-3.15.68-3.81-1.35-3.81-1.35-.52-1.3-1.26-1.65-1.26-1.65-1.03-.7.08-.69.08-.69 1.14.08 1.74 1.17 1.74 1.17 1.01 1.73 2.66 1.23 3.31.94.1-.74.4-1.23.72-1.51-2.51-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.17-3.04-.12-.29-.51-1.46.11-3.04 0 0 .95-.3 3.12 1.16a10.8 10.8 0 0 1 2.85-.38c.97 0 1.94.13 2.85.38 2.17-1.46 3.12-1.16 3.12-1.16.62 1.58.23 2.75.11 3.04.73.79 1.17 1.8 1.17 3.04 0 4.36-2.66 5.3-5.19 5.58.41.35.77 1.05.77 2.11v3.12c0 .3.2.66.79.54 4.49-1.5 7.72-5.73 7.72-10.72C23.27 5.5 18.27.5 12 .5Z"/></svg>
        GitHub
      </a>
      <button
        type="button"
        id="nav-burger"
        class="md:hidden inline-flex items-center justify-center h-9 w-9 rounded-lg border line"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg class="burger-open" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        <svg class="burger-close" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <nav id="nav-mobile" class="nav-drawer md:hidden" aria-label="Mobile primary">
    <a href="#ui" class="nav-mlink">UI</a>
    <a href="#features" class="nav-mlink">Features</a>
    <a href="#compare" class="nav-mlink">Compare</a>
    <a href="#architecture" class="nav-mlink">Architecture</a>
    <a href="#quickstart" class="nav-mlink">Quickstart</a>
    <a href="#safety" class="nav-mlink">Safety</a>
  </nav>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById('nav-burger');
    const drawer = document.getElementById('nav-mobile');
    const root = document.querySelector('.nav-root');
    if (!btn || !drawer || !root) return;
    const close = () => {
      root.classList.remove('nav-open');
      btn.setAttribute('aria-expanded', 'false');
    };
    btn.addEventListener('click', () => {
      const open = root.classList.toggle('nav-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    window.addEventListener('resize', () => { if (window.innerWidth >= 768) close(); });
  })();
</script>

<style>
  .nav-link { position: relative; transition: color 0.18s ease; }
  .nav-link:hover { color: var(--fg); }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -4px;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.25s ease;
  }
  .nav-link:hover::after { transform: scaleX(1); }

  .nav-root .burger-close { display: none; }
  .nav-root.nav-open .burger-open { display: none; }
  .nav-root.nav-open .burger-close { display: inline-block; }

  .nav-drawer {
    display: none;
    flex-direction: column;
    padding: 6px 16px 14px;
    gap: 2px;
    border-top: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 94%, transparent);
    backdrop-filter: blur(10px);
  }
  .nav-root.nav-open .nav-drawer { display: flex; animation: nav-drop 0.22s ease both; }
  @keyframes nav-drop {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .nav-mlink {
    padding: 11px 6px;
    font-size: 14px;
    color: var(--muted);
    border-bottom: 1px dashed color-mix(in oklab, var(--line) 80%, transparent);
  }
  .nav-mlink:last-child { border-bottom: 0; }
  .nav-mlink:active { color: var(--accent); }
</style>
