---
<header class="sticky top-0 z-50 glass border-b line">
  <div class="container-x flex h-14 items-center justify-between">
    <a href="#top" class="flex items-center gap-2 font-mono text-sm tracking-tight">
      <span aria-hidden="true" class="text-lg leading-none">&#128238;</span>
      <span class="font-semibold">deadLetter</span>
      <span class="text-[10px] px-1.5 py-0.5 rounded border line" style="color:var(--muted)">v1.2.0</span>
    </a>
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6 text-[13px]" style="color:var(--muted)">
      <a href="#ui" class="hover:text-[color:var(--fg)] transition-colors">UI</a>
      <a href="#features" class="hover:text-[color:var(--fg)] transition-colors">Features</a>
      <a href="#architecture" class="hover:text-[color:var(--fg)] transition-colors">Architecture</a>
      <a href="#quickstart" class="hover:text-[color:var(--fg)] transition-colors">Quickstart</a>
      <a href="#compare" class="hover:text-[color:var(--fg)] transition-colors">Compare</a>
      <a href="#api" class="hover:text-[color:var(--fg)] transition-colors">API</a>
      <a href="#safety" class="hover:text-[color:var(--fg)] transition-colors">Safety</a>
    </nav>
    <div class="flex items-center gap-2">
      <a
        href="https://hub.docker.com/r/peixotomdb/deadletter"
        class="hidden sm:inline-flex items-center gap-2 h-9 px-3 rounded-lg text-[12px] font-mono border line hover:border-[color:var(--line-strong)] transition-colors"
        rel="noopener noreferrer"
        target="_blank"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M13 3h8v8h-8zM3 13h8v8H3zM13 13h8v8h-8zM3 3h8v8H3z" stroke="currentColor" stroke-width="1.4"/></svg>
        docker pull
      </a>
      <a
        href="https://github.com/peixotomdb/deadletter"
        rel="noopener noreferrer"
        target="_blank"
        class="inline-flex items-center gap-2 h-9 px-3 rounded-lg text-[12px] font-mono bg-[color:var(--fg)] text-[color:var(--bg)] hover:opacity-90 transition-opacity"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.73 5.5.73 11.77c0 4.99 3.24 9.22 7.73 10.72.57.1.78-.25.78-.55v-2c-3.15.68-3.81-1.35-3.81-1.35-.52-1.3-1.26-1.65-1.26-1.65-1.03-.7.08-.69.08-.69 1.14.08 1.74 1.17 1.74 1.17 1.01 1.73 2.66 1.23 3.31.94.1-.74.4-1.23.72-1.51-2.51-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.17-3.04-.12-.29-.51-1.46.11-3.04 0 0 .95-.3 3.12 1.16a10.8 10.8 0 0 1 2.85-.38c.97 0 1.94.13 2.85.38 2.17-1.46 3.12-1.16 3.12-1.16.62 1.58.23 2.75.11 3.04.73.79 1.17 1.8 1.17 3.04 0 4.36-2.66 5.3-5.19 5.58.41.35.77 1.05.77 2.11v3.12c0 .3.2.66.79.54 4.49-1.5 7.72-5.73 7.72-10.72C23.27 5.5 18.27.5 12 .5Z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</header>
