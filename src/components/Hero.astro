---
---
<section id="top" class="relative pt-20 pb-24 sm:pt-28 sm:pb-32">
  <div class="container-x grid lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-7">
      <div class="eyebrow mb-6">
        <span class="live-dot" aria-hidden="true"></span>
        Local-first message observability
      </div>

      <h1 class="text-[42px] sm:text-6xl lg:text-[78px] leading-[0.98] tracking-[-0.035em] font-semibold">
        Where messages
        <br />
        go to <span style="color:var(--accent)">rest</span>.
      </h1>

      <p class="mt-7 max-w-2xl text-[17px] sm:text-lg leading-relaxed" style="color:var(--muted)">
        A local-first cockpit for SMTP, Kafka, Redis, and webhooks —
        so your next test email lands in a UI, not a customer inbox.
        <span style="color:var(--fg)">One binary. One port. Zero accidental deliveries.</span>
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#ui"
          class="inline-flex items-center gap-2 h-11 px-5 rounded-xl text-sm font-medium bg-[color:var(--fg)] text-[color:var(--bg)] hover:opacity-90 transition-opacity"
        >
          See the UI
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href="#quickstart"
          class="inline-flex items-center gap-2 h-11 px-5 rounded-xl text-sm font-medium border line hover:border-[color:var(--line-strong)] transition-colors"
        >
          Run in 30 seconds
        </a>
      </div>

      <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl">
        <div class="hero-stat">
          <div class="hero-stat-v">30<span class="hero-stat-unit">s</span></div>
          <div class="hero-stat-k">to first capture</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-v">0<span class="hero-stat-unit"></span></div>
          <div class="hero-stat-k">surprise deliveries</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-v">1<span class="hero-stat-unit"> bin</span></div>
          <div class="hero-stat-k">Go · Docker · brew</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-v">MIT<span class="hero-stat-unit"></span></div>
          <div class="hero-stat-k">self-hosted · free</div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="hero-preview" role="group" aria-label="UI preview">
        <div class="hp-chrome">
          <span class="term-dot" style="background:#ef4444"></span>
          <span class="term-dot" style="background:#eab308"></span>
          <span class="term-dot" style="background:#22c55e"></span>
          <div class="hp-url">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none"><path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5Zm3 8V7a3 3 0 0 0-6 0v3h6Z" stroke="currentColor" stroke-width="1.4"/></svg>
            localhost:8025<span style="color:var(--accent)">/</span>
          </div>
          <span class="ml-auto flex items-center gap-1.5 font-mono text-[10px]" style="color:var(--subtle)">
            <span class="live-dot" aria-hidden="true"></span>live
          </span>
        </div>

        <div class="hp-body">
          <span class="hp-pill">
            <span class="live-dot" aria-hidden="true"></span>
            LIVE · 6693 CAPTURED
          </span>

          <h3 class="hp-title">
            messages go to <span class="hp-strike">rest</span>
          </h3>

          <div class="hp-grid">
            <article class="hp-card">
              <div class="hp-card-head">
                <span class="hp-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z" stroke="currentColor" stroke-width="1.6"/><path d="m3 7 9 7 9-7" stroke="currentColor" stroke-width="1.6"/></svg></span>
                <div>
                  <div class="hp-name">Email</div>
                  <div class="hp-v">6693 <span class="hp-k">captured</span></div>
                </div>
              </div>
              <div class="hp-status ok"><span></span>listening :1025</div>
            </article>

            <article class="hp-card">
              <div class="hp-card-head">
                <span class="hp-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="6" cy="6" r="2" stroke="currentColor" stroke-width="1.6"/><circle cx="6" cy="18" r="2" stroke="currentColor" stroke-width="1.6"/><circle cx="18" cy="12" r="2" stroke="currentColor" stroke-width="1.6"/><path d="m8 7 8 4M8 17l8-4" stroke="currentColor" stroke-width="1.6"/></svg></span>
                <div>
                  <div class="hp-name">Kafka</div>
                  <div class="hp-v">:9092 <span class="hp-k">broker</span></div>
                </div>
              </div>
              <div class="hp-status warn"><span></span>offline</div>
            </article>

            <article class="hp-card">
              <div class="hp-card-head">
                <span class="hp-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="6" rx="8" ry="3" stroke="currentColor" stroke-width="1.6"/><path d="M4 6v12c0 1.66 3.58 3 8 3s8-1.34 8-3V6M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3" stroke="currentColor" stroke-width="1.6"/></svg></span>
                <div>
                  <div class="hp-name">Redis</div>
                  <div class="hp-v">8.6.2 <span class="hp-k">version</span></div>
                </div>
              </div>
              <div class="hp-status ok"><span></span>connected</div>
            </article>

            <article class="hp-card accent">
              <div class="hp-card-head">
                <span class="hp-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 16.98h-5.99c-1.1 0-1.95.94-2.48 1.9A4 4 0 0 1 2 17c.01-.7.2-1.4.57-2"/><path d="m6 17 3.13-5.78c.53-.97.1-2.18-.5-3.1a4 4 0 1 1 6.89-4.06"/><path d="m12 6 3.13 5.73C15.66 12.7 16.9 13 18 13a4 4 0 0 1 0 8"/></svg></span>
                <div>
                  <div class="hp-name">Webhooks <span class="hp-new">NEW</span></div>
                  <div class="hp-v">/webhooks/*</div>
                </div>
              </div>
              <div class="hp-status ok"><span></span>listening</div>
            </article>
          </div>
        </div>

        <div class="hp-foot">
          <span class="live-dot" aria-hidden="true"></span>
          <span>deadLetter v1.2.0 · replay-ready · zero deliveries</span>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <span class="tag accent">SMTP :1025</span>
        <span class="tag">HTTP :8025</span>
        <span class="tag">SSE live</span>
        <span class="tag new">Webhooks</span>
      </div>
    </div>
  </div>

  <!-- trust / tape row -->
  <div class="container-x mt-20">
    <div class="tape-mask overflow-hidden">
      <div class="tape-track text-[12px] font-mono" style="color:var(--muted)">
        {
          Array.from({ length: 2 }).map(() => (
            <div class="flex items-center gap-10 whitespace-nowrap">
              <span>SMTP sink</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>HTML sandbox</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Raw .eml on disk</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Replay on demand</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Retention windows</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Kafka browser</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Schema Registry</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Redis Pub/Sub</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>Webhooks</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>SSE stream</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
              <span>CLI · deadletterctl</span>
              <span aria-hidden="true" style="color:var(--subtle)">·</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero-stat {
    padding: 10px 14px;
    border-left: 2px solid color-mix(in oklab, var(--accent) 40%, var(--line));
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hero-stat-v {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat-unit {
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    margin-left: 2px;
  }
  .hero-stat-k {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    color: var(--subtle);
    text-transform: uppercase;
  }
  .hero-preview {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 88%, transparent);
    box-shadow:
      0 1px 0 color-mix(in oklab, var(--fg) 6%, transparent) inset,
      0 40px 100px -40px color-mix(in oklab, var(--accent) 35%, transparent),
      0 10px 30px -10px rgba(0,0,0,0.45);
  }
  .hp-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-bottom: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 70%, transparent);
  }
  .hp-url {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg) 55%, transparent);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--muted);
  }
  .hp-body {
    padding: 22px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    background:
      radial-gradient(ellipse 70% 80% at 50% -20%, color-mix(in oklab, var(--accent) 18%, transparent), transparent 55%),
      color-mix(in oklab, var(--bg) 45%, black);
  }
  .hp-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 11px;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, #22c55e 45%, var(--line));
    background: color-mix(in oklab, #22c55e 8%, transparent);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #86efac;
  }
  .hp-title {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.028em;
    color: var(--fg);
    text-align: center;
    line-height: 1.08;
  }
  .hp-strike {
    position: relative;
    color: color-mix(in oklab, var(--accent) 85%, var(--fg));
  }
  .hp-strike::after {
    content: "";
    position: absolute;
    left: -5%; right: -5%;
    top: 52%;
    height: 2.5px;
    background: var(--accent);
    transform: rotate(-3deg);
    border-radius: 2px;
  }
  .hp-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    width: 100%;
    margin-top: 4px;
  }
  .hp-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 11px 12px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 85%, transparent);
  }
  .hp-card.accent {
    border-color: color-mix(in oklab, var(--accent) 45%, var(--line));
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--accent) 10%, transparent), transparent 60%),
      color-mix(in oklab, var(--bg-elev) 85%, transparent);
  }
  .hp-card-head {
    display: flex;
    align-items: center;
    gap: 9px;
  }
  .hp-ico {
    display: inline-flex;
    width: 26px;
    height: 26px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid var(--line);
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    flex-shrink: 0;
  }
  .hp-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--fg);
  }
  .hp-v {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg);
    white-space: nowrap;
  }
  .hp-k {
    color: var(--subtle);
    letter-spacing: 0.12em;
    font-size: 9px;
    text-transform: uppercase;
    margin-left: 4px;
  }
  .hp-new {
    margin-left: 4px;
    font-family: var(--font-mono);
    font-size: 8.5px;
    padding: 1px 5px;
    border-radius: 4px;
    background: var(--accent);
    color: #0b0a09;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .hp-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 9px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    width: max-content;
  }
  .hp-status span {
    width: 5px; height: 5px; border-radius: 999px;
  }
  .hp-status.ok   { color: #86efac; background: color-mix(in oklab, #22c55e 12%, transparent); }
  .hp-status.ok   span { background: #22c55e; box-shadow: 0 0 0 3px color-mix(in oklab, #22c55e 25%, transparent); }
  .hp-status.warn { color: var(--warn); background: color-mix(in oklab, var(--warn) 12%, transparent); }
  .hp-status.warn span { background: var(--warn); box-shadow: 0 0 0 3px color-mix(in oklab, var(--warn) 25%, transparent); }
  .hp-foot {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    background: color-mix(in oklab, var(--bg-elev) 65%, transparent);
  }
</style>
