---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title = 'deadLetter — where messages go to rest',
  description = 'Local-first message observability for development. Capture SMTP, inspect email safely, browse Kafka, monitor Redis, fire webhooks. One Go binary. Zero accidental deliveries by default.',
  image = '/og-image.png',
  keywords = 'smtp testing, local smtp server, email capture, kafka ui, redis monitor, webhooks debugger, mailhog alternative, mailcatcher alternative, mailpit alternative, dev email inbox, message observability, sse event stream, go smtp, docker smtp',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://deadletter.dev').toString();
const ogImage = new URL(image, Astro.site ?? 'https://deadletter.dev').toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'deadLetter',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'macOS, Linux, Windows (Docker)',
      description,
      url: Astro.site?.toString() ?? 'https://deadletter.dev',
      image: ogImage,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      license: 'https://opensource.org/licenses/MIT',
      softwareVersion: '1.2.0',
    },
    {
      '@type': 'WebSite',
      name: 'deadLetter',
      url: Astro.site?.toString() ?? 'https://deadletter.dev',
      description,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="peixotomdb" />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="theme-color" content="#fafaf9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0a09" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="deadLetter" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="deadLetter dashboard — where messages go to rest" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="pt_PT" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@peixotomdb" />
    <meta name="twitter:creator" content="@peixotomdb" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="deadLetter dashboard — where messages go to rest" />

    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="preconnect" href="https://hub.docker.com" crossorigin />
    <link rel="preconnect" href="https://github.com" crossorigin />
    <link rel="dns-prefetch" href="https://hub.docker.com" />
    <link rel="dns-prefetch" href="https://github.com" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
